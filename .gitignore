# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.stackdump
Thumbs.db
desktop.ini

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# claude code
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
src/app/.next/

# screenshots / inspection scripts (local dev only)
/screenshots/
/docs/innopay-guide-raw/
/scripts/inspect-payments-response.ts
/scripts/screenshot-payments-mobile.ts
/scripts/screenshot-vbank-admin.ts
